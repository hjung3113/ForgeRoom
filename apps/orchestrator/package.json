{
  "name": "orchestrator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "smoke:openclaw": "node scripts/openclaw-live-smoke.mjs",
    "db:migrate": "tsc -p tsconfig.build.json && node dist/db/migrate.js",
    "lint": "eslint .",
    "dev:studio": "FORGEROOM_STUDIO=1 mastra dev --dir src/mastra"
  },
  "dependencies": {
    "@mastra/core": "1.36.0",
    "better-sqlite3": "^12.10.0",
    "discord.js": "^14.26.4",
    "drizzle-orm": "^0.45.2",
    "octokit": "^5.0.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "mastra": "1.10.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
